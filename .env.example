# Copie este arquivo para ".env" antes de subir o projeto com Docker.
# Todos os hosts (mongo / mysql) correspondem aos nomes dos servicos no docker-compose.yml.

# Servidor
NODE_ENV=development
PORT=3000

# MongoDB (carro, moto, marca de roupa)
MONGO_URI=mongodb://mongo:27017/trabfullstack

# MySQL (usuarios)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=trabfullstack
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
MYSQL_ROOT_PASSWORD=rootpassword

# JWT
JWT_SECRET=troque-este-valor-por-um-segredo-forte-e-aleatorio
JWT_EXPIRES_IN=1h

# Segredo necessario para registrar um usuario com papel "admin" (ver POST /api/auth/register)
ADMIN_BOOTSTRAP_SECRET=troque-este-segredo-de-bootstrap
